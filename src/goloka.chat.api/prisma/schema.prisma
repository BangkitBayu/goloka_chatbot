// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum SessionStatus {
  PENDING
  CONNECTED
  DISCONNECTED
}

enum CampaignStatus {
  DRAFT
  QUEUED
  RUNNING
  DONE
  FAILED
}

// ─────────────────────────────────────────────
//  MODELS
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  quota     Int      @default(100) // blast message quota
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions    WhatsAppSession[]
  contacts    Contact[]
  campaigns   BroadcastCampaign[]
  chatbotRules ChatbotRule[]

  @@map("users")
}

model WhatsAppSession {
  id          String        @id @default(uuid())
  userId      String
  phoneNumber String
  sessionData Json?         // Baileys auth state (serialized)
  status      SessionStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns BroadcastCampaign[]
  chatbotRules ChatbotRule[]

  @@map("whatsapp_sessions")
}

model Contact {
  id          String   @id @default(uuid())
  userId      String
  name        String
  phoneNumber String
  groupTag    String?  // e.g. "vip", "reseller", "regular"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phoneNumber])
  @@map("contacts")
}

model BroadcastCampaign {
  id             String         @id @default(uuid())
  userId         String
  sessionId      String
  name           String
  messageContent String         @db.Text
  mediaUrl       String?
  scheduledAt    DateTime?
  status         CampaignStatus @default(DRAFT)
  sentCount      Int            @default(0)
  failedCount    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("broadcast_campaigns")
}

model ChatbotRule {
  id              String   @id @default(uuid())
  userId          String
  sessionId       String
  triggerKeyword  String
  responseMessage String   @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, triggerKeyword])
  @@map("chatbot_rules")
}
